{
  "name": "@mewhhaha/typeclasses",
  "version": "0.5.1",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": "./src/mod.ts",
    "./prelude": "./src/prelude.ts",
    "./typeclass": "./src/typeclass.ts",
    "./typeclasses": "./src/typeclasses.ts",
    "./maybe": "./src/maybe.ts",
    "./either": "./src/either.ts",
    "./validation": "./src/validation.ts",
    "./identity": "./src/identity.ts",
    "./fn": "./src/fn.ts",
    "./tuple": "./src/tuple.ts",
    "./array": "./src/array.ts",
    "./predicate": "./src/predicate.ts",
    "./task": "./src/task.ts",
    "./effects": "./src/effects.ts",
    "./parallel": "./src/parallel.ts",
    "./stm": "./src/stm.ts",
    "./reader": "./src/reader.ts",
    "./state": "./src/state.ts",
    "./writer": "./src/writer.ts",
    "./list": "./src/list.ts",
    "./tagged": "./src/tagged.ts",
    "./loop": "./src/loop.ts",
    "./transform": "./tools/transform_do_program.ts",
    "./transform/plugin": "./tools/transform_plugin.ts"
  },
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "deno.json",
      "deno.lock",
      "src/**/*.ts",
      "tools/transform_do_program.ts",
      "tools/transform_plugin.ts",
      "learn_you_a_typeclasses_for_greater_good/README.md",
      "learn_you_a_typeclasses_for_greater_good/**/*.ts"
    ],
    "exclude": [
      "src/*.test.ts"
    ]
  },
  "imports": {
    "effect": "npm:effect@3.21.4",
    "esbuild": "npm:esbuild@0.25.12",
    "fp-ts/Either": "npm:fp-ts@2.16.11/lib/Either.js",
    "fp-ts/Option": "npm:fp-ts@2.16.11/lib/Option.js",
    "fp-ts/ReaderTaskEither": "npm:fp-ts@2.16.11/lib/ReaderTaskEither.js",
    "fp-ts/StateReaderTaskEither": "npm:fp-ts@2.16.11/lib/StateReaderTaskEither.js",
    "fp-ts/function": "npm:fp-ts@2.16.11/lib/function.js",
    "purify-ts/Either": "npm:purify-ts@2.1.4/Either",
    "purify-ts/Maybe": "npm:purify-ts@2.1.4/Maybe",
    "rolldown": "npm:rolldown@1.1.5",
    "typescript": "npm:typescript@5.9.3",
    "true-myth/maybe": "npm:true-myth@9.1.0/maybe",
    "true-myth/result": "npm:true-myth@9.1.0/result"
  },
  "tasks": {
    "bench": "deno bench --allow-env --allow-read --allow-write=/tmp bench/*.bench.ts",
    "bench:case-studies": "deno bench --allow-env --allow-read --allow-write=/tmp bench/case_studies_transformer.bench.ts",
    "case-study": "deno run --allow-read case_studies/main.ts",
    "transform": "deno run --allow-env --allow-read --allow-write tools/transform_do_program.ts",
    "check:portability": "deno run --allow-env --allow-read tools/check_portability.ts",
    "test:entrypoints": "deno run --allow-env --allow-read tools/package_entrypoint_smoke.ts",
    "test:node": "node --experimental-strip-types tools/node_portability_smoke.ts",
    "test:bun": "bun tools/node_portability_smoke.ts",
    "publish": "deno task prepublish && deno publish",
    "publish:dry-run": "deno publish --dry-run --allow-dirty",
    "fmt:check": "deno fmt --check",
    "doc:check": "deno doc --lint src/mod.ts tools/transform_do_program.ts tools/transform_plugin.ts",
    "check": "deno check src/mod.ts src/*.test.ts examples/*.ts case_studies/**/*.ts bench/*.bench.ts tools/*.ts learn_you_a_typeclasses_for_greater_good/**/*.ts",
    "example": "deno run --allow-read=examples,src examples/main.ts",
    "learn": "deno run learn_you_a_typeclasses_for_greater_good/main.ts",
    "test": "deno test",
    "test:transformer": "deno test --allow-env --allow-ffi --allow-read --allow-run --allow-write tools/transform_do_program_checks.ts tools/transform_plugin_checks.ts",
    "test:benchmarks": "deno bench --filter '/$a/' bench/algorithm_contexts.bench.ts bench/iterable_pipeline.bench.ts",
    "verify": "deno task fmt:check && deno task check && deno lint && deno task doc:check && deno task test && deno task test:transformer && deno task test:benchmarks && deno task check:portability && deno task test:entrypoints && deno task test:node && deno task test:bun && deno task example && deno task learn && deno task case-study",
    "prepublish": "deno task verify && deno task publish:dry-run"
  }
}
